# Copy this file to .env.local and fill in your key to enable AI outreach drafting.
# Without it, the Outreach page falls back to a built-in template draft (no AI).
ANTHROPIC_API_KEY=sk-ant-...

# Model used for drafting customer messages. Opus = best quality, Haiku = fastest/cheapest.
OUTREACH_MODEL=claude-opus-4-8
